{
  "name": "@nowdoing/sdk",
  "version": "0.1.0",
  "description": "Client SDK for the NowDoing macOS app loopback HTTP API.",
  "keywords": ["nowdoing", "time-tracking", "macos", "sdk", "client"],
  "homepage": "https://github.com/nowdoingapp/nowdoingmac/tree/main/sdks/js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nowdoingapp/nowdoingmac.git",
    "directory": "sdks/js"
  },
  "bugs": "https://github.com/nowdoingapp/nowdoingmac/issues",
  "license": "MIT",
  "author": "Mattes <m.mattes@meey.de>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run test/live.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
