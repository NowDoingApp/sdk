{
  "name": "@nowdoing/sdk",
  "version": "0.1.0",
  "description": "Client SDK for the NowDoing macOS app loopback HTTP API.",
  "keywords": ["nowdoing", "time-tracking", "macos", "sdk", "client"],
  "homepage": "https://github.com/NowDoingApp/sdk/tree/main/js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NowDoingApp/sdk.git",
    "directory": "js"
  },
  "bugs": "https://github.com/NowDoingApp/sdk/issues",
  "license": "MIT",
  "author": "NowDoing <hello@nowdoing.app>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "vitest run test/live.test.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
